#########################################################################################################
##	This is an example .gitignore file for Vivado, please treat it as an example as 
##	it might not be complete. In addition, XAPP 1165 should be followed.
#########################################################################################################
#########
#Exclude all
#########
*
!.gitignore
###########################################################################
##	DO NOT IGNORE THE FOLLOWING FILES
###########################################################################
!Bender.*
!cnn_core_wrapper/
!cnn_core_wrapper/**/

!out/
!out/**

!data/
!data/**

!hw/
!hw/**
!scripts/
!scripts/**
scripts/__pycache__/
scripts/**/*.pyc
!add_sources.tcl
###########################################################################
##	VIVADO
###########################################################################
#########
#Source files:
#########
#Do NOT ignore VHDL, Verilog, block diagrams or EDIF files.
!*.vhd
!*.v
!*.sv
!*.bd
!*.edif
#########
#IP files
#########
#.xci: synthesis and implemented not possible - you need to return back to the previous version to generate output products
#.xci + .dcp: implementation possible but not re-synthesis
#*.xci(www.spiritconsortium.org)
!*.xci
#*.dcp - NOT included, large binary Vivado checkpoint files (re-generatable)
#*.pb  - NOT included, Vivado internal protobuf binary files (not human-readable)
!*.vds
#All bd comments and layout coordinates are stored within .ui
!*.ui
!*.ooc
#########
#System Generator
#########
!*.mdl
!*.slx
!*.bxml
#########
#Simulation logic analyzer
#########
!*.wcfg
!*.coe
#########
#MIG
#########
!*.prj
!*.mem
#########
#Project files
#########
#XPR  +  *.XML ? XPR (Files are merged into a single XPR file for 2014.1 version)
#Do NOT ignore *.xpr files
!*.xpr
#Include *.xml files for 2013.4 or earlier version
!*.xml
#########
#Constraint files
#########
#Do NOT ignore *.xdc files
!*.xdc
#########
#TCL - files
#########
!*.tcl
#########
#Journal - files
#########
#!*.jou
#########
#Reports
#########
!*.rpt
!*.txt
!*.vdi
#########
#C-files
#########
#*.c - NOT included, xsim generates large C files (xsim_20.c etc.)
!*.h
!*.elf
!*.bmm
!*.xmp

.DS_Store
**/.DS_Store

###########################################################################
##	ALWAYS EXCLUDE (overrides whitelist above)
###########################################################################
# Vivado waveform and report databases (large binary, not useful as logs)
*.wdb
*.rpx

# Vivado xsim compiled simulation objects (binary, re-generated each run)
**/xsim.dir/**/*.mem
**/xsim.dir/**/xsimk
**/xsim.dir/**/*.c
**/TempBreakPointFile.txt

# Simulation result CSV and log files ARE tracked (see !out/** above)
# Generated Vivado project under out/ (re-creatable by run_behavioral_sim.py)
out/behavioral_sim/vivado_project/
